---
import BaseLayout from '@/layouts/BaseLayout.astro';
import MunicipalHomeExperience from '@/components/islands/MunicipalHomeExperience';
import { DEFAULT_SITE, DEFAULT_THEME } from '@/lib/defaults';
import { serializeThemeStyleBlock } from '@/lib/theme';

const site = DEFAULT_SITE;
const theme = DEFAULT_THEME;
---

<BaseLayout title={site.name} description={site.short_description}>
    <style is:inline set:html={serializeThemeStyleBlock(theme)}></style>
    <MunicipalHomeExperience
        client:load
        site={site}
        theme={theme}
        enableNightMode={true}
        news={[]}
        events={[]}
        agendaItems={[]}
        meetings={[]}
        authorities={[]}
        procedures={[]}
        blocks={[]}
    />
</BaseLayout>
