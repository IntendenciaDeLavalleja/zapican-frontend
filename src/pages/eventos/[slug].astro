---
import SiteLayout from '@/layouts/SiteLayout.astro';
import { eventsApi, siteApi } from '@/lib/api';
import { repairApiPayload } from '@/lib/utils';

export async function getStaticPaths() {
  try {
    const response = await eventsApi.list();
    const events = repairApiPayload(response.events || []);
    return events.map((e) => ({ params: { slug: e.slug } }));
  } catch {
    return [];
  }
}

const slug = Astro.params.slug || '';

const [configResp, detailResp, blocksResp, eventsResp] = await Promise.all([
  siteApi.config(),
  eventsApi.detail(slug),
  siteApi.blocks('home'),
  eventsApi.list(),
]);

const site   = repairApiPayload(configResp.site);
const theme  = repairApiPayload(configResp.theme);
const navBlock = repairApiPayload((blocksResp.blocks || []).find((b) => b.block_type === 'navigation'));
const event  = repairApiPayload(detailResp);
const allEvents = repairApiPayload(eventsResp.events || []);
const relatedEvents = allEvents.filter((e) => e.slug !== event.slug).slice(0, 3);

function fmtDate(iso: string | null | undefined) {
  if (!iso) return '';
  return new Intl.DateTimeFormat('es-UY', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' }).format(new Date(iso));
}
function fmtTime(iso: string | null | undefined) {
  if (!iso) return '';
  return new Intl.DateTimeFormat('es-UY', { hour: '2-digit', minute: '2-digit' }).format(new Date(iso));
}
function fmtShortDate(iso: string | null | undefined) {
  if (!iso) return { day: '--', month: '---' };
  const d = new Date(iso);
  return {
    day: String(d.getDate()),
    month: new Intl.DateTimeFormat('es-UY', { month: 'short' }).format(d).toUpperCase(),
  };
}

const dateLabel = fmtDate(event.start_datetime);
const timeLabel = fmtTime(event.start_datetime);
const endTimeLabel = event.end_datetime ? fmtTime(event.end_datetime) : null;
---

<SiteLayout
  site={site}
  theme={theme}
  navBlock={navBlock}
  title={event.title}
  description={event.location_name ? `${dateLabel} — ${event.location_name}` : dateLabel}
  ogImage={event.cover_url || site.hero_url || null}
>
  <article class="mx-auto max-w-5xl">

    {/* ── Hero card */}
    <div class="evento-shell overflow-hidden rounded-[2.6rem] border border-white/60 bg-white/88 shadow-[0_34px_80px_rgba(15,23,42,0.12)] backdrop-blur-xl">

      {/* Cover banner */}
      <div class="relative h-64 w-full overflow-hidden sm:h-80 lg:h-96">
        {event.cover_url ? (
          <img src={event.cover_url} alt={event.title} class="h-full w-full object-cover" />
        ) : (
          <div class="h-full w-full" style={`background: linear-gradient(135deg, var(--site-primary, #1e3a8a), var(--site-secondary, #0ea5e9))`} />
        )}
        {/* Gradient overlay */}
        <div class="absolute inset-0" style="background: linear-gradient(180deg, rgba(0,0,0,0.05) 0%, rgba(0,0,0,0.62) 100%)" />
        {/* Category badge */}
        {event.category && (
          <div class="absolute left-6 top-6">
            <span class="rounded-full border border-white/30 bg-white/20 px-4 py-1.5 text-[0.65rem] font-bold uppercase tracking-[0.22em] text-white backdrop-blur-md">
              {event.category}
            </span>
          </div>
        )}
        {/* Back link */}
        <a href="/eventos" class="absolute right-6 top-6 inline-flex items-center gap-2 rounded-full border border-white/25 bg-black/25 px-4 py-1.5 text-[0.7rem] font-semibold text-white backdrop-blur-md transition hover:bg-black/40">
          ← Todos los eventos
        </a>
        {/* Title over image */}
        <div class="absolute bottom-0 left-0 right-0 p-6 sm:p-8">
          <h1 class="text-3xl font-black leading-tight text-white drop-shadow-xl sm:text-4xl lg:text-5xl">
            {event.title}
          </h1>
        </div>
      </div>

      {/* Meta bar */}
      <div class="evento-meta-bar flex flex-wrap items-center gap-x-6 gap-y-3 border-b px-6 py-5 sm:px-8">
        {/* Date badge */}
        <div class="flex items-center gap-3">
          <div class="flex h-12 w-12 flex-col items-center justify-center rounded-xl text-white shadow-md shrink-0"
               style={`background: linear-gradient(135deg, var(--site-primary, #1e3a8a), var(--site-secondary, #0ea5e9))`}>
            <span class="text-[0.55rem] font-bold uppercase leading-none opacity-90">{fmtShortDate(event.start_datetime).month}</span>
            <span class="text-xl font-black leading-none mt-0.5">{fmtShortDate(event.start_datetime).day}</span>
          </div>
          <div>
            <p class="text-sm font-semibold capitalize evento-text-primary">{dateLabel}</p>
            <p class="text-xs evento-text-secondary mt-0.5">
              {timeLabel}{endTimeLabel ? ` — ${endTimeLabel}` : ''}
            </p>
          </div>
        </div>

        {event.location_name && (
          <div class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" style={`color: var(--site-primary, #2563eb)`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>
            </svg>
            <span class="text-sm font-medium evento-text-primary">{event.location_name}</span>
          </div>
        )}

        {event.address && (
          <div class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 evento-text-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="16" height="20" x="4" y="2" rx="2"/><path d="M9 22v-4h6v4"/><path d="M8 6h.01M16 6h.01M12 6h.01M12 10h.01M12 14h.01M16 10h.01M16 14h.01M8 10h.01M8 14h.01"/>
            </svg>
            <span class="text-xs evento-text-secondary">{event.address}</span>
          </div>
        )}

        {(event.latitude && event.longitude) && (
          <a
            href={`https://www.google.com/maps?q=${event.latitude},${event.longitude}`}
            target="_blank"
            rel="noopener noreferrer"
            class="ml-auto inline-flex items-center gap-1.5 rounded-full px-4 py-2 text-xs font-semibold text-white shadow-sm transition hover:-translate-y-0.5 hover:shadow-md"
            style={`background: linear-gradient(135deg, var(--site-primary, #1e3a8a), var(--site-secondary, #0ea5e9))`}
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>
            </svg>
            Ver en mapa
          </a>
        )}
      </div>

      {/* Description */}
      {event.description_html ? (
        <div class="evento-content news-rich-content p-6 sm:p-8 lg:p-10" set:html={event.description_html} />
      ) : (
        <div class="p-6 sm:p-8">
          <p class="text-sm evento-text-secondary italic">Este evento no tiene descripción disponible.</p>
        </div>
      )}
    </div>

    {/* ── Related events */}
    {relatedEvents.length > 0 && (
      <section class="mt-12">
        <div class="mb-6 flex items-end justify-between gap-4">
          <div>
            <p class="text-[0.72rem] font-semibold uppercase tracking-[0.34em] text-slate-500">Otros eventos</p>
            <h2 class="mt-2 text-3xl font-black tracking-[-0.04em] text-slate-950">Más de la agenda municipal</h2>
          </div>
          <a href="/eventos" class="text-sm font-semibold uppercase tracking-[0.2em]" style={`color: var(--site-secondary)`}>Ver todos</a>
        </div>

        <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {relatedEvents.map((e) => {
            const sd = fmtShortDate(e.start_datetime);
            return (
              <a href={`/eventos/${e.slug}`}
                 class="evento-card group overflow-hidden rounded-[2rem] border border-white/60 bg-white/88 shadow-[0_16px_40px_rgba(15,23,42,0.10)] backdrop-blur-xl transition hover:-translate-y-1 hover:shadow-[0_24px_56px_rgba(15,23,42,0.14)]">
                {/* Thumbnail */}
                <div class="relative h-36 w-full overflow-hidden">
                  {e.cover_url ? (
                    <img src={e.cover_url} alt={e.title} class="h-full w-full object-cover transition duration-500 group-hover:scale-105" />
                  ) : (
                    <div class="h-full w-full" style={`background: linear-gradient(135deg, var(--site-primary, #1e3a8a), var(--site-secondary, #0ea5e9))`} />
                  )}
                  {/* Date badge */}
                  <div class="absolute bottom-3 left-3 flex flex-col items-center justify-center rounded-xl px-2.5 py-2 text-white shadow-lg"
                       style={`background: linear-gradient(135deg, var(--site-primary, #1e3a8a), var(--site-secondary, #0ea5e9))`}>
                    <span class="text-[0.55rem] font-bold uppercase leading-none opacity-90">{sd.month}</span>
                    <span class="text-lg font-black leading-none mt-0.5">{sd.day}</span>
                  </div>
                </div>
                {/* Info */}
                <div class="p-4 sm:p-5">
                  <p class="text-sm font-bold leading-snug text-slate-900 line-clamp-2 group-hover:text-[color:var(--site-primary,#2563eb)] transition-colors">{e.title}</p>
                  {e.location_name && (
                    <p class="mt-2 flex items-center gap-1.5 text-xs text-slate-500">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>
                      </svg>
                      {e.location_name}
                    </p>
                  )}
                </div>
              </a>
            );
          })}
        </div>
      </section>
    )}
  </article>
</SiteLayout>

<style>
  .evento-shell {
    border-color: rgba(255,255,255,0.6);
    background-color: rgba(255,255,255,0.88);
  }
  .evento-meta-bar {
    border-color: rgba(15,23,42,0.07);
  }
  .evento-text-primary { color: #1e293b; }
  .evento-text-secondary { color: #64748b; }
  .evento-text-muted { color: #94a3b8; }

  html[data-theme-mode='night'] .evento-shell {
    background-color: rgba(11, 23, 37, 0.88) !important;
    border-color: rgba(148, 163, 184, 0.12) !important;
  }
  html[data-theme-mode='night'] .evento-meta-bar {
    border-color: rgba(148, 163, 184, 0.12) !important;
  }
  html[data-theme-mode='night'] .evento-text-primary { color: #f1f5f9 !important; }
  html[data-theme-mode='night'] .evento-text-secondary { color: rgba(203,213,225,0.75) !important; }
  html[data-theme-mode='night'] .evento-text-muted { color: rgba(148,163,184,0.6) !important; }
  html[data-theme-mode='night'] .evento-content { color: #e2e8f0 !important; }
  html[data-theme-mode='night'] .evento-card {
    background-color: rgba(11, 23, 37, 0.82) !important;
    border-color: rgba(148, 163, 184, 0.12) !important;
  }
  html[data-theme-mode='night'] .evento-card .text-slate-900 { color: #f1f5f9 !important; }
  html[data-theme-mode='night'] .evento-card .text-slate-500 { color: rgba(203,213,225,0.70) !important; }
  html[data-theme-mode='night'] h2.text-slate-950 { color: #f8fafc !important; }
  html[data-theme-mode='night'] p.text-slate-500 { color: rgba(203,213,225,0.70) !important; }
</style>
