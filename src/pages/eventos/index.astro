---
import BaseLayout from '@/layouts/BaseLayout.astro';
import EventsPageExperience from '@/components/islands/EventsPageExperience';
import { DEFAULT_SITE, DEFAULT_THEME } from '@/lib/defaults';
import { serializeThemeStyleBlock } from '@/lib/theme';

const site = DEFAULT_SITE;
const theme = DEFAULT_THEME;
---

<BaseLayout title="Agenda de eventos" description="Actividades, encuentros y celebraciones del municipio.">
  <style is:inline set:html={serializeThemeStyleBlock(theme)}></style>
  <EventsPageExperience client:load site={site} theme={theme} />
</BaseLayout>
