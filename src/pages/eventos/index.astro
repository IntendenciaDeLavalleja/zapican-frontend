---
import SiteLayout from '@/layouts/SiteLayout.astro';
import { eventsApi, siteApi } from '@/lib/api';
import { repairApiPayload } from '@/lib/utils';

const [configResp, eventsResp, blocksResp] = await Promise.all([
  siteApi.config(),
  eventsApi.list(),
  siteApi.blocks('home'),
]);

const site      = repairApiPayload(configResp.site);
const theme     = repairApiPayload(configResp.theme);
const navBlock  = repairApiPayload((blocksResp.blocks || []).find((b) => b.block_type === 'navigation'));
const allEvents = repairApiPayload(eventsResp.events || []);

const now = new Date();
const upcoming = allEvents.filter((e) => e.start_datetime && new Date(e.start_datetime) >= now);
const past     = allEvents.filter((e) => e.start_datetime && new Date(e.start_datetime) < now).reverse();

function fmtShortDate(iso: string | null | undefined) {
  if (!iso) return { day: '--', month: '---', weekday: '' };
  const d = new Date(iso);
  return {
    day:     String(d.getDate()),
    month:   new Intl.DateTimeFormat('es-UY', { month: 'short' }).format(d).toUpperCase(),
    weekday: new Intl.DateTimeFormat('es-UY', { weekday: 'short' }).format(d),
    full:    new Intl.DateTimeFormat('es-UY', { day: 'numeric', month: 'long', year: 'numeric' }).format(d),
    time:    new Intl.DateTimeFormat('es-UY', { hour: '2-digit', minute: '2-digit' }).format(d),
  };
}
---

<SiteLayout
  site={site}
  theme={theme}
  navBlock={navBlock}
  title="Agenda de Eventos"
  description={`Próximos eventos del municipio de ${site.name}`}
  ogImage={site.hero_url || null}
>
  <div class="mx-auto max-w-5xl">

    {/* ── Page header */}
    <header class="eventos-header mb-10 overflow-hidden rounded-[2.2rem] px-8 py-12 sm:px-12 sm:py-14"
            style={`background: linear-gradient(135deg, var(--site-primary, #1e3a8a) 0%, var(--site-secondary, #0ea5e9) 100%)`}>
      <a href="/" class="mb-5 inline-flex items-center gap-2 rounded-full border border-white/25 bg-white/15 px-4 py-1.5 text-[0.7rem] font-semibold text-white backdrop-blur-md transition hover:bg-white/25">
        ← Inicio
      </a>
      <p class="text-[0.72rem] font-bold uppercase tracking-[0.36em] text-white/70">Municipio</p>
      <h1 class="mt-2 text-4xl font-black text-white sm:text-5xl">Agenda de eventos</h1>
      <p class="mt-3 max-w-lg text-base text-white/80">
        Actividades, encuentros y celebraciones del municipio.
      </p>
      <div class="mt-6 flex flex-wrap items-center gap-3">
        <span class="inline-flex items-center gap-2 rounded-full bg-white/15 px-4 py-2 text-sm font-semibold text-white backdrop-blur-md">
          <span class="h-2 w-2 rounded-full bg-green-400 shadow-[0_0_6px_2px_rgba(74,222,128,0.5)]"></span>
          {upcoming.length} próximos
        </span>
        {past.length > 0 && (
          <span class="inline-flex items-center gap-2 rounded-full bg-white/10 px-4 py-2 text-sm text-white/70">
            {past.length} realizados
          </span>
        )}
      </div>
    </header>

    {/* ── Upcoming events */}
    {upcoming.length === 0 ? (
      <div class="eventos-empty-card rounded-[2rem] border p-10 text-center">
        <p class="text-3xl mb-3">📅</p>
        <p class="text-base font-semibold text-slate-700">No hay eventos próximos por el momento.</p>
        <p class="mt-1 text-sm text-slate-500">Volvé a consultar pronto.</p>
      </div>
    ) : (
      <section>
        <p class="mb-5 text-[0.72rem] font-semibold uppercase tracking-[0.34em] text-slate-500">Próximos eventos</p>
        <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {upcoming.map((e) => {
            const sd = fmtShortDate(e.start_datetime);
            return (
              <a href={`/eventos/${e.slug}`}
                 class="evento-listing-card group overflow-hidden rounded-[2rem] border border-white/60 bg-white/88 shadow-[0_16px_40px_rgba(15,23,42,0.10)] backdrop-blur-xl transition hover:-translate-y-1.5 hover:shadow-[0_28px_60px_rgba(15,23,42,0.14)]">
                {/* Thumbnail */}
                <div class="relative h-40 w-full overflow-hidden">
                  {e.cover_url ? (
                    <img src={e.cover_url} alt={e.title} class="h-full w-full object-cover transition duration-500 group-hover:scale-105" />
                  ) : (
                    <div class="flex h-full w-full items-center justify-center"
                         style={`background: linear-gradient(135deg, var(--site-primary, #1e3a8a), var(--site-secondary, #0ea5e9))`}>
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-white/40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <rect width="18" height="18" x="3" y="4" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/><path d="M8 14h.01M12 14h.01M16 14h.01M8 18h.01M12 18h.01M16 18h.01"/>
                      </svg>
                    </div>
                  )}
                  {/* Date badge */}
                  <div class="absolute bottom-3 left-3 flex flex-col items-center justify-center rounded-xl px-2.5 py-2 text-white shadow-lg"
                       style={`background: linear-gradient(135deg, var(--site-primary, #1e3a8a), var(--site-secondary, #0ea5e9))`}>
                    <span class="text-[0.55rem] font-bold uppercase leading-none opacity-90">{sd.month}</span>
                    <span class="text-xl font-black leading-none mt-0.5">{sd.day}</span>
                  </div>
                  {e.is_featured && (
                    <div class="absolute right-3 top-3">
                      <span class="rounded-full bg-amber-400 px-2.5 py-0.5 text-[0.6rem] font-bold uppercase tracking-[0.18em] text-amber-900 shadow">Destacado</span>
                    </div>
                  )}
                </div>
                {/* Info */}
                <div class="p-5">
                  {e.category && (
                    <span class="mb-2 inline-block rounded-full bg-slate-100 px-2.5 py-0.5 text-[0.62rem] font-semibold uppercase tracking-[0.18em] text-slate-500">{e.category}</span>
                  )}
                  <p class="text-sm font-bold leading-snug text-slate-900 line-clamp-2 group-hover:text-[color:var(--site-primary,#2563eb)] transition-colors">{e.title}</p>
                  <div class="mt-3 flex flex-wrap items-center gap-x-3 gap-y-1 text-xs text-slate-500">
                    <span>{sd.full}</span>
                    <span class="opacity-40">·</span>
                    <span>{sd.time} hs</span>
                  </div>
                  {e.location_name && (
                    <p class="mt-1.5 flex items-center gap-1.5 text-xs text-slate-500">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>
                      </svg>
                      {e.location_name}
                    </p>
                  )}
                </div>
              </a>
            );
          })}
        </div>
      </section>
    )}

    {/* ── Past events */}
    {past.length > 0 && (
      <section class="mt-14">
        <p class="mb-5 text-[0.72rem] font-semibold uppercase tracking-[0.34em] text-slate-500">Eventos realizados</p>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {past.map((e) => {
            const sd = fmtShortDate(e.start_datetime);
            return (
              <a href={`/eventos/${e.slug}`}
                 class="evento-past-card group flex items-center gap-4 overflow-hidden rounded-[1.6rem] border border-white/50 bg-white/75 px-5 py-4 shadow-[0_8px_24px_rgba(15,23,42,0.07)] backdrop-blur-md transition hover:shadow-[0_14px_36px_rgba(15,23,42,0.11)]">
                {/* Date badge */}
                <div class="shrink-0 flex flex-col items-center justify-center rounded-xl bg-slate-100 px-2.5 py-2 min-w-[48px]">
                  <span class="text-[0.55rem] font-bold uppercase leading-none text-slate-500">{sd.month}</span>
                  <span class="text-xl font-black leading-none mt-0.5 text-slate-700">{sd.day}</span>
                </div>
                <div class="min-w-0">
                  <p class="text-sm font-semibold text-slate-700 line-clamp-1 group-hover:text-[color:var(--site-primary,#2563eb)] transition-colors">{e.title}</p>
                  {e.location_name && <p class="mt-0.5 text-xs text-slate-400 truncate">{e.location_name}</p>}
                </div>
              </a>
            );
          })}
        </div>
      </section>
    )}

  </div>
</SiteLayout>

<style>
  html[data-theme-mode='night'] .eventos-header {
    /* keeps the gradient, just needs label color fixes handled globally */
  }
  html[data-theme-mode='night'] .eventos-empty-card {
    background: rgba(11,23,37,0.82) !important;
    border-color: rgba(148,163,184,0.14) !important;
  }
  html[data-theme-mode='night'] .eventos-empty-card .text-slate-700 { color: #e2e8f0 !important; }
  html[data-theme-mode='night'] .eventos-empty-card .text-slate-500 { color: rgba(203,213,225,0.7) !important; }

  html[data-theme-mode='night'] .evento-listing-card {
    background-color: rgba(11,23,37,0.84) !important;
    border-color: rgba(148,163,184,0.12) !important;
  }
  html[data-theme-mode='night'] .evento-listing-card .text-slate-900 { color: #f1f5f9 !important; }
  html[data-theme-mode='night'] .evento-listing-card .text-slate-500 { color: rgba(203,213,225,0.7) !important; }
  html[data-theme-mode='night'] .evento-listing-card .bg-slate-100 { background: rgba(30,50,75,0.6) !important; }
  html[data-theme-mode='night'] .evento-listing-card .text-slate-500 { color: rgba(148,163,184,0.8) !important; }

  html[data-theme-mode='night'] .evento-past-card {
    background-color: rgba(11,23,37,0.76) !important;
    border-color: rgba(148,163,184,0.12) !important;
  }
  html[data-theme-mode='night'] .evento-past-card .bg-slate-100 { background: rgba(20,40,65,0.8) !important; }
  html[data-theme-mode='night'] .evento-past-card .text-slate-700 { color: #e2e8f0 !important; }
  html[data-theme-mode='night'] .evento-past-card .text-slate-500 { color: rgba(148,163,184,0.5) !important; }
  html[data-theme-mode='night'] .evento-past-card .text-slate-400 { color: rgba(100,116,139,0.8) !important; }
  html[data-theme-mode='night'] p.text-slate-500 { color: rgba(203,213,225,0.65) !important; }
</style>
