---
import SiteLayout from '@/layouts/SiteLayout.astro';
import NewsCard from '@/components/news/NewsCard.astro';
import { newsApi, siteApi } from '@/lib/api';
import { formatNewsDate, getNewsTransitionNames, repairNewsDetail, repairNewsSummary } from '@/lib/news';
import { repairApiPayload } from '@/lib/utils';

export async function getStaticPaths() {
  try {
    const response = await newsApi.list();
    const posts = repairApiPayload(response.news || []);

    return posts.map((post) => ({
      params: { slug: post.slug },
    }));
  } catch {
    return [];
  }
}

const slug = Astro.params.slug || '';

const [configResp, detailResp, newsResp, blocksResp] = await Promise.all([
  siteApi.config(),
  newsApi.detail(slug),
  newsApi.list(),
  siteApi.blocks('home'),
]);

const site = repairApiPayload(configResp.site);
const theme = repairApiPayload(configResp.theme);
const navBlock = repairApiPayload((blocksResp.blocks || []).find((block) => block.block_type === 'navigation'));
const post = repairNewsDetail(detailResp);
const allPosts = repairApiPayload(newsResp.news || []).map((item) => repairNewsSummary(item));
const relatedPosts = allPosts.filter((item) => item.slug !== post.slug).slice(0, 3);
const transitionNames = getNewsTransitionNames(post.slug);
---

<SiteLayout
  site={site}
  theme={theme}
  navBlock={navBlock}
  title={post.seo?.title || post.title}
  description={post.seo?.description || post.excerpt || site.short_description}
  ogImage={post.seo?.og_image || post.cover_url || site.hero_url || null}
>
  <article class="mx-auto max-w-6xl">
    <div class="news-detail-shell rounded-[2.6rem] border border-white/60 bg-white/88 p-6 shadow-[0_34px_80px_rgba(15,23,42,0.12)] backdrop-blur-xl sm:p-8 lg:p-12" style={{ viewTransitionName: transitionNames.card }}>
      <div class="flex flex-wrap items-center gap-3 text-[0.72rem] font-semibold uppercase tracking-[0.28em] text-slate-500">
        <a href="/novedades" class="inline-flex items-center rounded-full border border-slate-300 px-4 py-2 text-[0.68rem] tracking-[0.22em] text-slate-700 transition hover:border-slate-950 hover:text-slate-950">← Volver a novedades</a>
        <span>{formatNewsDate(post.published_at)}</span>
        {post.category?.name && <span>{post.category.name}</span>}
        {post.author && <span>{post.author}</span>}
      </div>

      <div class="mt-8 grid grid-cols-1 gap-8 lg:grid-cols-[1.15fr_0.85fr] lg:items-start">
        <div>
          <h1 class="text-4xl font-black tracking-[-0.05em] text-slate-950 sm:text-5xl lg:text-6xl" style={{ viewTransitionName: transitionNames.title }}>{post.title}</h1>
          {post.excerpt && <p class="mt-6 max-w-3xl text-lg leading-8 text-slate-600">{post.excerpt}</p>}
        </div>

        <div class="overflow-hidden rounded-[2rem] bg-slate-100 shadow-[0_24px_64px_rgba(15,23,42,0.14)]">
          {post.cover_url ? (
            <img src={post.cover_url} alt={post.title} class="h-full w-full object-cover" style={{ viewTransitionName: transitionNames.image }} />
          ) : (
            <div class="flex min-h-[18rem] items-center justify-center bg-[radial-gradient(circle_at_top,rgba(29,120,116,0.28),rgba(13,59,102,0.16))] text-sm font-semibold text-slate-700">Sin imagen destacada</div>
          )}
        </div>
      </div>

      <div class="news-rich-content mt-10 rounded-[2rem] bg-white/82 p-6 ring-1 ring-black/5 sm:p-8 lg:p-10" set:html={post.content_html || '<p>Artículo sin contenido disponible.</p>'}></div>
    </div>

    {relatedPosts.length > 0 && (
      <section class="mt-12">
        <div class="mb-6 flex items-end justify-between gap-4">
          <div>
            <p class="text-[0.72rem] font-semibold uppercase tracking-[0.34em] text-slate-500">Seguir leyendo</p>
            <h2 class="mt-3 text-3xl font-black tracking-[-0.04em] text-slate-950">Más novedades del municipio</h2>
          </div>
          <a href="/novedades" class="text-sm font-semibold uppercase tracking-[0.2em] text-[var(--site-secondary)]">Ver todas</a>
        </div>

        <div class="grid grid-cols-1 gap-8 md:grid-cols-2 xl:grid-cols-3">
          {relatedPosts.map((item) => (
            <NewsCard post={item} />
          ))}
        </div>
      </section>
    )}
  </article>
</SiteLayout>