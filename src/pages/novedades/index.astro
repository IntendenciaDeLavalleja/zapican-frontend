---
import SiteLayout from '@/layouts/SiteLayout.astro';
import NewsCard from '@/components/news/NewsCard.astro';
import { newsApi, siteApi } from '@/lib/api';
import { DEFAULT_SITE, DEFAULT_THEME } from '@/lib/defaults';
import { repairApiPayload } from '@/lib/utils';

const PER_PAGE = 7;
const currentPage = Math.max(1, Number(Astro.url.searchParams.get('pagina') || 1));

let site = DEFAULT_SITE;
let theme = DEFAULT_THEME;
let navBlock = undefined;
let posts = [];
let totalPages: number = 1;
let newsHeaderContent: Record<string, string> = {};

try {
  const [configResp, newsResp, blocksResp, novBlocksResp] = await Promise.all([
    siteApi.config(),
    newsApi.list({ page: currentPage, per_page: PER_PAGE }),
    siteApi.blocks('home'),
    siteApi.blocks('novedades'),
  ]);

  site = repairApiPayload(configResp.site);
  theme = repairApiPayload(configResp.theme);
  navBlock = repairApiPayload((blocksResp.blocks || []).find((b) => b.block_type === 'navigation'));
  posts = repairApiPayload(newsResp.news || []);
  totalPages = newsResp.pages || 1;
  const headerBlock = (novBlocksResp.blocks || []).find((b) => b.block_type === 'news_header');
  newsHeaderContent = (headerBlock?.content ?? {}) as Record<string, string>;
} catch {
  posts = [];
}

// Header color config (set from admin panel)
const hCfg = newsHeaderContent;
const headingColor = hCfg.heading_color || '#0f172a';
const subtitleColor = hCfg.subtitle_color || '#475569';
const labelColor = hCfg.label_color || '#64748b';

const featuredPost = posts[0] ?? null;
const gridPosts = posts.slice(1);

// Build page-number list with ellipsis for long ranges
const pageLinks: (number | '…')[] = [];
if (totalPages <= 7) {
  for (let i = 1; i <= totalPages; i++) pageLinks.push(i);
} else {
  pageLinks.push(1);
  if (currentPage > 3) pageLinks.push('…');
  for (let i = Math.max(2, currentPage - 1); i <= Math.min(totalPages - 1, currentPage + 1); i++) {
    pageLinks.push(i);
  }
  if (currentPage < totalPages - 2) pageLinks.push('…');
  pageLinks.push(totalPages);
}
---

<SiteLayout
  site={site}
  theme={theme}
  navBlock={navBlock}
  title="Novedades"
  description="Artículos, noticias y novedades del municipio."
  ogImage={featuredPost?.cover_url || site.hero_url || null}
>
  <section class="mx-auto max-w-7xl">

    <!-- Encabezado con colores configurables -->
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-[0.72rem] font-semibold uppercase tracking-[0.34em]"
         style={`color: ${labelColor}`}>Novedades</p>
      <h1 class="mt-4 text-4xl font-black tracking-[-0.04em] sm:text-6xl"
          style={`color: ${headingColor}`}>Blog y actualidad del municipio</h1>
      <p class="mt-5 text-base leading-8 sm:text-lg"
         style={`color: ${subtitleColor}`}>Artículos desarrollados, obras, servicios, cultura local y la agenda pública del territorio.</p>
    </div>

    <!-- Artículo destacado (primero de la página) -->
    {featuredPost && (
      <div class="mt-12">
        <NewsCard post={featuredPost} featured />
      </div>
    )}

    <!-- Grilla de artículos restantes -->
    {gridPosts.length > 0 && (
      <div class="mt-10 grid grid-cols-1 gap-8 md:grid-cols-2 xl:grid-cols-3">
        {gridPosts.map((post) => (
          <NewsCard post={post} />
        ))}
      </div>
    )}

    {posts.length === 0 && (
      <p class="mt-16 text-center text-slate-500">No hay artículos publicados.</p>
    )}

    <!-- Paginación -->
    {totalPages > 1 && (
      <nav class="mt-14 flex items-center justify-center gap-2 flex-wrap" aria-label="Paginación de artículos">
        {currentPage > 1 && (
          <a href={`/novedades?pagina=${currentPage - 1}`}
             class="inline-flex items-center gap-1.5 px-4 py-2.5 rounded-xl border border-slate-200 bg-white/80 text-slate-700 text-sm font-medium hover:bg-white hover:border-slate-300 hover:shadow-sm transition-all backdrop-blur-sm">
            ← Anterior
          </a>
        )}

        {pageLinks.map((p) =>
          p === '…'
            ? <span class="px-1 text-slate-400 select-none">…</span>
            : <a href={`/novedades?pagina=${p}`}
                 class={`inline-flex h-10 w-10 items-center justify-center rounded-xl text-sm font-semibold transition-all ${
                   p === currentPage
                     ? 'text-white shadow-md'
                     : 'border border-slate-200 bg-white/80 text-slate-700 hover:bg-white hover:border-slate-300 hover:shadow-sm backdrop-blur-sm'
                 }`}
                 style={p === currentPage
                   ? `background-color: ${theme.colors?.primary || '#2563eb'}; border-color: ${theme.colors?.primary || '#2563eb'}`
                   : ''}>
                {p}
              </a>
        )}

        {currentPage < totalPages && (
          <a href={`/novedades?pagina=${currentPage + 1}`}
             class="inline-flex items-center gap-1.5 px-4 py-2.5 rounded-xl border border-slate-200 bg-white/80 text-slate-700 text-sm font-medium hover:bg-white hover:border-slate-300 hover:shadow-sm transition-all backdrop-blur-sm">
            Siguiente →
          </a>
        )}
      </nav>
    )}

  </section>
</SiteLayout>