---
import BaseLayout from '@/layouts/BaseLayout.astro';
import NewsPageExperience from '@/components/islands/NewsPageExperience';
import { DEFAULT_SITE, DEFAULT_THEME } from '@/lib/defaults';
import { serializeThemeStyleBlock } from '@/lib/theme';

const site = DEFAULT_SITE;
const theme = DEFAULT_THEME;
---

<BaseLayout title="Novedades" description="Artículos, noticias y novedades del municipio.">
  <style is:inline set:html={serializeThemeStyleBlock(theme)}></style>
  <NewsPageExperience client:load site={site} theme={theme} />
</BaseLayout>