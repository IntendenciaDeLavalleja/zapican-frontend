---
export interface Props {
  title?: string;
  message?: string;
}
const { title = 'Sin contenido', message = 'No hay elementos para mostrar.' } = Astro.props;
---
<div class="border border-dashed rounded-lg p-8 text-center opacity-70">
  <p class="font-semibold">{title}</p>
  <p class="text-sm">{message}</p>
</div>
