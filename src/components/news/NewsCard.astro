---
import type { NewsSummary } from '@/lib/api/types';
import { formatNewsDate, getNewsHref, getNewsTransitionNames, repairNewsSummary } from '@/lib/news';

export interface Props {
  post: NewsSummary;
  featured?: boolean;
}

const { post, featured = false } = Astro.props;
const item = repairNewsSummary(post);
const href = getNewsHref(item.slug);
const transitionNames = getNewsTransitionNames(item.slug);
---

<a href={href} class="group block h-full" aria-label={`Leer novedad: ${item.title}`}>
  <article class={`municipal-news-card h-full overflow-hidden rounded-[2.2rem] bg-white shadow-[0_28px_64px_rgba(15,23,42,0.12)] ring-1 ring-black/5 transition-transform duration-300 group-hover:-translate-y-1 ${featured ? 'lg:grid lg:grid-cols-[1.1fr_0.9fr]' : ''}`} style={{ viewTransitionName: transitionNames.card }}>
    <div class={`relative overflow-hidden bg-slate-100 ${featured ? 'min-h-[18rem]' : 'h-64'}`}>
      {item.cover_url ? (
        <img src={item.cover_url} alt={item.title} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]" loading="lazy" style={{ viewTransitionName: transitionNames.image }} />
      ) : (
        <div class="flex h-full items-center justify-center bg-[radial-gradient(circle_at_top,rgba(29,120,116,0.28),rgba(13,59,102,0.16))] text-sm font-semibold text-slate-700">
          Sin imagen destacada
        </div>
      )}
    </div>
    <div class="flex flex-col p-7">
      <div class="flex items-center gap-3 text-[0.68rem] font-semibold uppercase tracking-[0.3em] text-slate-400">
        <span>{formatNewsDate(item.published_at)}</span>
        {item.category?.name && <span>{item.category.name}</span>}
      </div>
      <h2 class={`mt-4 font-semibold tracking-tight text-slate-950 transition-colors group-hover:text-[var(--site-secondary)] ${featured ? 'text-3xl leading-tight' : 'text-2xl'}`} style={{ viewTransitionName: transitionNames.title }}>
        {item.title}
      </h2>
      <p class="mt-4 line-clamp-4 text-sm leading-7 text-slate-600">{item.excerpt || 'Contenido editorial publicado desde el backend municipal.'}</p>
      <div class="mt-auto pt-6 text-sm font-semibold uppercase tracking-[0.2em] text-[var(--site-secondary)]">
        Leer artículo
      </div>
    </div>
  </article>
</a>